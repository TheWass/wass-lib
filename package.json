{
  "name": "@thewass/wass-lib",
  "version": "0.7.0",
  "license": "MIT",
  "author": "TheWass",
  "description": "This is a TS Library where I keep my commonly used, generic functions and modules consolidated and up to date.",
  "repository": {
    "type": "git",
    "url": "git@github.com-thewass:TheWass/wass-lib.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "sideEffects": [
    "./dist/esm/extensions/array.js",
    "./dist/esm/extensions/string.js",
    "./dist/cjs/extensions/array.js",
    "./dist/cjs/extensions/string.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    },
    "./helpers": {
      "types": "./dist/types/helpers/index.d.ts",
      "import": "./dist/esm/helpers/index.js",
      "require": "./dist/cjs/helpers/index.js",
      "default": "./dist/esm/helpers/index.js"
    },
    "./utilities": {
      "types": "./dist/types/utilities/index.d.ts",
      "import": "./dist/esm/utilities/index.js",
      "require": "./dist/cjs/utilities/index.js",
      "default": "./dist/esm/utilities/index.js"
    },
    "./node": {
      "types": "./dist/types/node/index.d.ts",
      "import": "./dist/esm/node/index.js",
      "require": "./dist/cjs/node/index.js",
      "default": "./dist/esm/node/index.js"
    },
    "./extensions/array": {
      "types": "./dist/types/extensions/array.d.ts",
      "import": "./dist/esm/extensions/array.js",
      "require": "./dist/cjs/extensions/array.js",
      "default": "./dist/esm/extensions/array.js"
    },
    "./extensions/string": {
      "types": "./dist/types/extensions/string.d.ts",
      "import": "./dist/esm/extensions/string.js",
      "require": "./dist/cjs/extensions/string.js",
      "default": "./dist/esm/extensions/string.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/cjs/**/!(*.tsbuildinfo)",
    "dist/esm/**/!(*.tsbuildinfo)",
    "dist/types/**/!(*.tsbuildinfo)",
    "LICENSE.md",
    "package.json",
    "readme.md"
  ],
  "typesVersions": {
    ">=4.2": {
      "*": [
        "dist/types/*"
      ]
    }
  },
  "scripts": {
    "build:clean": "node ./scripts/clean-pub.cjs",
    "build": "npm run build:clean && npm run compile",
    "compile": "tsc -b ./src/tsconfig.esm.json ./src/tsconfig.cjs.json ./src/tsconfig.types.json",
    "lint": "tsc --noEmit",
    "build:verify": "npm run lint",
    "test": "mocha '**/*.spec.ts'",
    "prepublishOnly": "npm run test && npm run build && npm run build:verify"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.3",
    "chai": "^6.2.2",
    "eslint": "^10.4.1",
    "mocha": "^11.7.6",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "dependencies": {
    "@types/luxon": "^3.7.1",
    "luxon": "^3.7.2"
  }
}
