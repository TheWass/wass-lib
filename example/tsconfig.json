{
    "compilerOptions": {
        "esModuleInterop": true,
        "allowJs": false,
        "noImplicitAny": true,
        "sourceMap": true,
        "skipLibCheck": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "dist",
        "moduleResolution": "node16",
        "module": "node16",
        "lib": ["ES2018"],
        "target": "ES6"
    },
    "exclude": ["node_modules", "dist"]
}
